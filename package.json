{
  "name": "react-vtree",
  "version": "3.0.0-beta.3",
  "description": "React component for efficiently rendering large tree structures",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "check": "concurrently --kill-others-on-fail --group --names lint,oxlint,typecheck,test,build npm:lint npm:oxlint npm:typecheck npm:test npm:build",
    "clean": "rimraf coverage dist storybook-static",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "full-prepare": "npm run clean && concurrently --kill-others-on-fail --group --names format,lint,oxlint,typecheck,test,build npm:format:check npm:lint npm:oxlint npm:typecheck npm:test npm:build",
    "lint": "eslint . --flag unstable_native_nodejs_ts_config",
    "lint:fix": "npm run eslint -- --fix",
    "oxlint": "oxlint -c .oxlintrc.json",
    "prepare": "echo 'update me'",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lodin/react-vtree.git"
  },
  "keywords": [
    "infinite",
    "react",
    "reactjs",
    "react-component",
    "react-virtualized",
    "tree",
    "virtual",
    "virtualized"
  ],
  "author": "Vlad Rindevich <rindevich.vs@gmail.com> (https://github.com/Lodin)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Lodin/react-vtree/issues"
  },
  "homepage": "https://github.com/Lodin/react-vtree#readme",
  "devDependencies": {
    "@storybook/react-vite": "10.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "@types/react-virtualized-auto-sizer": "1.0.8",
    "@types/react-window": "1.8.8",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-vaadin": "1.0.0-beta.5",
    "eslint-plugin-oxlint": "1.57.0",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-virtualized-auto-sizer": "2.0.3",
    "react-window": "1.8.11",
    "rimraf": "6.1.3",
    "storybook": "10.3.3",
    "tsdown": "0.21.7",
    "tsgolint": "0.0.1",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-window": ">= 1.8.5"
  },
  "dependencies": {
    "react-merge-refs": "3.0.2"
  },
  "overrides": {
    "vite": "$vite"
  }
}
